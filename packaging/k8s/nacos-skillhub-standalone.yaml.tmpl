apiVersion: v1
kind: Secret
metadata:
  name: __RELEASE_NAME__-auth
  namespace: __NAMESPACE__
  labels:
    app.kubernetes.io/name: nacos-skillhub
    app.kubernetes.io/instance: __RELEASE_NAME__
type: Opaque
stringData:
  NACOS_AUTH_TOKEN: "__AUTH_TOKEN__"
  NACOS_AUTH_IDENTITY_KEY: "__IDENTITY_KEY__"
  NACOS_AUTH_IDENTITY_VALUE: "__IDENTITY_VALUE__"
---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: __RELEASE_NAME__
  namespace: __NAMESPACE__
  labels:
    app.kubernetes.io/name: nacos-skillhub
    app.kubernetes.io/instance: __RELEASE_NAME__
---
apiVersion: v1
kind: Service
metadata:
  name: __RELEASE_NAME__
  namespace: __NAMESPACE__
  labels:
    app.kubernetes.io/name: nacos-skillhub
    app.kubernetes.io/instance: __RELEASE_NAME__
spec:
  type: __SERVICE_TYPE__
  selector:
    app.kubernetes.io/name: nacos-skillhub
    app.kubernetes.io/instance: __RELEASE_NAME__
  ports:
    - name: http
      port: 8848
      targetPort: http
    - name: grpc
      port: 9848
      targetPort: grpc
    - name: raft
      port: 9849
      targetPort: raft
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: __RELEASE_NAME__-data
  namespace: __NAMESPACE__
  labels:
    app.kubernetes.io/name: nacos-skillhub
    app.kubernetes.io/instance: __RELEASE_NAME__
spec:
  accessModes:
    - ReadWriteOnce
__STORAGE_CLASS_BLOCK__
  resources:
    requests:
      storage: __STORAGE_SIZE__
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: __RELEASE_NAME__
  namespace: __NAMESPACE__
  labels:
    app.kubernetes.io/name: nacos-skillhub
    app.kubernetes.io/instance: __RELEASE_NAME__
spec:
  replicas: __REPLICAS__
  selector:
    matchLabels:
      app.kubernetes.io/name: nacos-skillhub
      app.kubernetes.io/instance: __RELEASE_NAME__
  template:
    metadata:
      labels:
        app.kubernetes.io/name: nacos-skillhub
        app.kubernetes.io/instance: __RELEASE_NAME__
    spec:
      serviceAccountName: __RELEASE_NAME__
      containers:
        - name: nacos-skillhub
          image: __IMAGE_REF__
          imagePullPolicy: __IMAGE_PULL_POLICY__
          env:
            - name: MODE
              value: "__NACOS_MODE__"
            - name: NACOS_AUTH_ENABLE
              value: "__AUTH_ENABLE__"
            - name: NACOS_AUTH_TOKEN
              valueFrom:
                secretKeyRef:
                  name: __RELEASE_NAME__-auth
                  key: NACOS_AUTH_TOKEN
            - name: NACOS_AUTH_IDENTITY_KEY
              valueFrom:
                secretKeyRef:
                  name: __RELEASE_NAME__-auth
                  key: NACOS_AUTH_IDENTITY_KEY
            - name: NACOS_AUTH_IDENTITY_VALUE
              valueFrom:
                secretKeyRef:
                  name: __RELEASE_NAME__-auth
                  key: NACOS_AUTH_IDENTITY_VALUE
            - name: JAVA_OPT_EXT
              value: "__JAVA_OPT_EXT__"
          ports:
            - name: http
              containerPort: 8848
            - name: grpc
              containerPort: 9848
            - name: raft
              containerPort: 9849
          readinessProbe:
            tcpSocket:
              port: http
            initialDelaySeconds: 30
            periodSeconds: 10
            failureThreshold: 18
          livenessProbe:
            tcpSocket:
              port: http
            initialDelaySeconds: 90
            periodSeconds: 20
            failureThreshold: 6
          volumeMounts:
            - name: data
              mountPath: /home/nacos/data
            - name: logs
              mountPath: /home/nacos/logs
      volumes:
        - name: data
          persistentVolumeClaim:
            claimName: __RELEASE_NAME__-data
        - name: logs
          emptyDir: {}
